# Copy this file to "keystore.properties" (same folder) and fill in real values.
# keystore.properties is gitignored and is used for LOCAL signed builds.
# CI (GitHub Actions) does NOT use this file - it uses repository secrets instead.

# Absolute path to your keystore, or a path relative to the android/ folder.
